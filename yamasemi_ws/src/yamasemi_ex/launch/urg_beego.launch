<launch>

	<!-- urg node launch -->
	<node pkg="urg_node" name="urg_node" type="urg_node" output="screen">
		<param name="serial_port"		value="/dev/serial/by-id/usb-Hokuyo_Data_Flex_for_USB_URG-Series_USB_Driver-if00" />
	</node>

	<!-- urg frame broadcaster: base_link to laser frame-->
	<node pkg="tf" 	name="base_link_to_laser" type="static_transform_publisher" args="0.0 0 0 0 0 0 /base_link /laser 100" />

</launch>
