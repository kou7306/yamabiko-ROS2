#!/usr/bin/env sh

# Yamabiko YP-Spur coordinator bridge
# 引数: $1 = パラメータファイルのパス

# デバイスパスを環境に合わせて変更してください
# 一般的には /dev/ttyACM0 または /dev/ttyUSB0
DEVICE="/dev/ttyACM0"

echo "Starting ypspur-coordinator with param: $1, device: $DEVICE"

ypspur-coordinator -p "$1" -d "$DEVICE" --reconnect

echo "ypspur-coordinator terminated"
